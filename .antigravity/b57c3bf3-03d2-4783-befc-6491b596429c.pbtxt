          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      id: \'rev-1\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      name: \'Victoria Vance\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      role: \'Luxury Connoisseur, Cond\303\251 Nast\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      rating: 5,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      comment: \"L\'\303\211toile is not a meal; it is absolute performance art. The Truffle Filet literally melted on contact, and the sommelier pair-ups were flawless. NorthByte has made an absolute masterpiece of a website for them too!\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      avatar: \'https://images.unsplash.com/photo-1534528741775-53994a69daeb?auto=format&fit=crop&q=80&w=200\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      date: \'June 2026\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      id: \'rev-2\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      name: \'Marcus Sterling\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      role: \'Tech Venture Partner\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      rating: 5,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      comment: \"The reservation interface was so clean and intuitive that I booked a client dinner in 10 seconds. The actual dinner somehow managed to exceed the premium web presentation. World-class in every metric.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      avatar: \'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=crop&q=80&w=200\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      date: \'May 2026\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      id: \'rev-3\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      name: \'Chef Akira Sato\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      role: \'Critique & Culinary Judge\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      rating: 5,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      comment: \"Meticulous. Jean-Luc\'s scale of seasoning is precise, and the scale of the website\'s layout matches that standard. Absolutely gorgeous user experience.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
