tween px-12 border-b border-white/5 backdrop-blur-xl bg-black/40 z-50\\\">\\n    <div class=\\\"flex items-center gap-2\\\">\\n      <div class=\\\"w-8 h-8 bg-blue-600 rounded-sm flex items-center justify-center font-bold text-lg\\\">N</div>\\n      <span class=\\\"text-xl font-medium tracking-tight\\\">NORTH<span class=\\\"font-light opacity-60\\\">BYTE</span></span>\\n    </div>\\n    <div class=\\\"flex items-center gap-10 text-sm font-medium tracking-wider uppercase opacity-70\\\">\\n      <a href=\\\"#\\\" class=\\\"hover:opacity-100 transition-opacity\\\">Cuisine</a>\\n      <a href=\\\"#\\\" class=\\\"hover:opacity-100 transition-opacity\\\">Experience</a>\\n      <a href=\\\"#\\\" class=\\\"hover:opacity-100 transition-opacity\\\">Menu</a>\\n      <a href=\\\"#\\\" class=\\\"hover:opacity-100 transition-opacity\\\">Gallery</a>\\n    </div>\\n    <button class=\\\"px-6 py-2.5 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold rounded-full shadow-lg shadow-blue-500/20 uppercase tracking-widest\\\">\\n      Reserve Table\\n    </button>\\n  </nav>\\n\\n  <!-- Main Content Viewport -->\\n  <main class=\\\"flex-1 grid grid-cols-12 relative overflow-hidden\\\">\\n    <!-- Background Glow -->\\n    <div class=\\\"absolute top-1/4 left-1/4 w-[500px] h-[500px] bg-blue-600/10 rounded-full blur-[120px] pointer-events-none\\\"></div>\\n    \\n    <!-- Left Section: Typography -->\\n    <div class=\\\"col-span-7 flex flex-col justify-center px-12 z-10\\\">\\n      <div class=\\\"flex items-center gap-3 mb-6\\\">\\n        <span class=\\\"w-8 h-[1px] bg-blue-500\\\"></span>\\n        <span class=\\\"text-xs uppercase tracking-[0.4em] text-blue-400 font-bold italic\\\">Michelin Starred Experience</span>\\n      </div>\\n      <h1 class=\\\"text-[84px] leading-[0.9] font-semibold tracking-tighter mb-8\\\">\\n        SAVOUR THE <br/>\\n        <span class=\\\"text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-indigo-600 italic\\\">EXTRAORDINARY.</span>\\n      </h1>\\n      <p class=\\\"text-lg text-slate-400 max-w-lg mb-10 leading-relaxed font-light\\\">\\n        A symphony of flavors, crafted by masters of the culinary arts. \\n        Redefining fine dining through technical precision and local soul.\\n      </p>\\n      <div class=\\\"flex items-center gap-6\\\">\\n        <button class=\\\"px-8 py-4 bg-white text-black font-bold uppercase tracking-wider text-sm rounded-none hover:bg-slate-200 transition-all\\\">\\n          Explore The Menu\\n        </button>\\n        <button class=\\\"flex items-center gap-3 text-sm uppercase tracking-widest font-bold border-b border-white/20 pb-1 hover:border-white transition-all\\\">\\n          View Wine List\\n        </button>\\n      </div>\\n    </div>\\n\\n    <!-- Right Section: Luxury Card/Imagery -->\\n    <div class=\\\"col-span-5 relative flex items-center justify-center pr-12\\\">\\n      <div class=\\\"relative w-full h-[520px] rounded-2xl overflow-hidden shadow-2xl border border-white/10 group\\\">\\n        <div class=\\\"absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-black/20 z-10\\\"></div>\\n        <img src=\\\"https://images.unsplash.com/photo-1559339352-11d035aa65de?auto=format&fit=crop&q=80&w=1000\\\" \\n             alt=\\\"Signature Dish\\\" \\n             class=\\\"absolute inset-0 w-full h-full object-cover scale-105\\\">\\n        \\n        <div class=\\\"absolute bottom-8 left-8 z-20\\\">\\n          <p class=\\\"text-xs uppercase tracking-widest text-blue-400 mb-2 font-bold\\\">Signature Dish</p>\\n          <h3 class=\\\"text-2xl font-serif italic mb-1\\\">Wagyu A5 Striploin</h3>\\n          <p class=\\\"text-sm text-slate-300 font-light\\\">Truffle Jus & Smoked Bone Marrow</p>\\n        </div>\\n        \\n        <div class=\\\"absolute top-8 right-8 z-20\\\">\\n          <div class=\\\"w-16 h-16 rounded-full border border-white/20 flex items-center justify-center backdrop-blur-md\\\">\\n            <span class=\\\"text-xs font-bold\\\">\342\202\2712,450</span>\\n          </div>\\n        </div>\\n      </div>\\n      \\n      <!-- Floating Meta Element -->\\n      <div class=\\\"absolute -bottom-4 -left-8 bg-[#0a0f1d] border border-white/10 p-6 rounded-xl shadow-2xl z-30 flex items-center gap-4\\\">\\n        <div class=\\\"flex flex-col\\\">\\n          <span class=\\\"text-xs opacity-50 uppercase tracking-tighter mb-1\\\">Award Winner</span>\\n          <span class=\\\"text-lg font-bold uppercase\\\">Best Interior 2024</span>\\n        </div>\\n        <div class=\\\"w-px h-10 bg-white/10\\\"></div>\\n        <div class=\\\"flex gap-1 text-blue-500\\\">\\n          <span>\342\230\205</span><span>\342\230\205</span><span>\342\230\205</span><span>\342\230\205</span><span>\342\230\205</span>\\n        </div>\\n      </div>\\n    </div>\\n  </main>\\n\\n  <!-- Bottom Info Rail -->\\n  <footer class=\\\"h-24 w-full border-t border-white/5 flex items-center px-12 bg-black/60 backdrop-blur-sm z-40\\\">\\n    <div class=\\\"grid grid-cols-4 w-full items-center\\\">\\n      <div class=\\\"flex flex-col border-r border-white/5\\\">\\n        <span class=\\\"text-[10px] uppercase tracking-widest text-slate-500 mb-1\\\">Location</span>\\n        <span class=\\\"text-sm font-medium\\\">Cyber Hub, Gurgaon</span>\\n      </div>\\n      <div class=\\\"flex flex-col border-r border-white/5 px-8\\\">\\n        <span class=\\\"text-[10px] uppercase tracking-widest text-slate-500 mb-1\\\">Opening Hours</span>\\n        <span class=\\\"text-sm font-medium\\\">12:00 PM \342\200\224 11:30 PM</span>\\n      </div>\\n      <div class=\\\"flex flex-col border-r border-white/5 px-8\\\">\\n        <span class=\\\"text-[10px] uppercase tracking-widest text-slate-500 mb-1\\\">Contact Us</span>\\n        <span class=\\\"text-sm font-medium\\\">+91 98765 43210</span>\\n      </div>\\n      <div class=\\\"flex justify-end gap-6 items-center pl-8\\\">\\n        <span class=\\\"text-[10px] uppercase tracking-widest text-slate-500\\\">Social</span>\\n        <div class=\\\"flex gap-4\\\">\\n          <div class=\\\"w-8 h-8 rounded-full border border-white/10 flex items-center justify-center hover:bg-white hover:text-black cursor-pointer transition-colors\\\">IG</div>\\n          <div class=\\\"w-8 h-8 rounded-full border border-white/10 flex items-center justify-center hover:bg-white hover:text-black cursor-pointer transition-colors\\\">FB</div>\\n        </div>\\n      </div>\\n    </div>\\n  </footer>\\n</div>\\n                    </body>\\n                  </html>\n[AIS_METADATA_SECTION_END]"
    items {
      text: "Apply the \"Elegant Dark\" design theme to the app.\n[AIS_METADATA_SECTION_START]\nDesign name: Elegant Dark\nDesign instructions: Extract ONLY the styling (colors, fonts, spacing, borders, shadows, backgrounds, gradients) and layout patterns (flexbox/grid structure, component arrangement) from the Design HTML below. Do NOT replace or restructure the existing app\'s HTML elements \342\200\224 preserve all existing components, content, and functionality. Only modify CSS/styling and adjust layout containers as needed to match the theme\'s aesthetic.\nDesign HTML:                   <!doctype html>\\n                  <html style=\\\"height: 100%; margin: 0;\\\">\\n                    <head>\\n                      <meta charset=\\\"UTF-8\\\" />\\n                      <meta name=\\\"viewport\\\" content=\\\"width=device-width, initial-scale=1.0\\\" />\\n                      <script src=\\\"https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4\\\"></script>\\n                      <link href=\\\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200\\\" rel=\\\"stylesheet\\\" />\\n                      <style>\\n                        body { margin: 0; height: 100%; display: flex; flex-direction: column; overflow: hidden; }\\n                        /* Fallback classes in case Tailwind fails to load in sandbox */\\n                        .h-full { height: 100%; }\\n                        .w-full { width: 100%; }\\n                        .flex { display: flex; }\\n                        .flex-col { flex-direction: column; }\\n                        .flex-1 { flex: 1 1 0%; }\\n                      </style>\\n                    </head>\\n                    <body>\\n                      <div class=\\\"h-[768px] w-[1024px] bg-[#030712] text-slate-100 flex flex-col overflow-hidden font-sans\\\">\\n  <!-- Sticky Glass Navbar -->\\n  <nav class=\\\"h-20 w-full flex items-center justify-between px-12 border-b border-white/5 backdrop-blur-xl bg-black/40 z-50\\\">\\n    <div class=\\\"flex items-center gap-2\\\">\\n      <div class=\\\"w-8 h-8 bg-blue-600 rounded-sm flex items-center justify-center font-bold text-lg\\\">N</div>\\n      <span class=\\\"text-xl font-medium tracking-tight\\\">NORTH<span class=\\\"font-light opacity-60\\\">BYTE</span></span>\\n    </div>\\n    <div class=\\\"flex items-center gap-10 text-sm font-medium tracking-wider uppercase opacity-70\\\">\\n      <a href=\\\"#\\\" class=\\\"hover:opacity-100 transition-opacity\\\">Cuisine</a>\\n      <a href=\\\"#\\\" class=\\\"hover:opacity-100 transition-opacity\\\">Experience</a>\\n      <a href=\\\"#\\\" class=\\\"hover:opacity-100 transition-opacity\\\">Menu</a>\\n      <a href=\\\"#\\\" class=\\\"hover:opacity-100 transition-opacity\\\">Gallery</a>\\n    </div>\\n    <button class=\\\"px-6 py-2.5 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold rounded-full shadow-lg shadow-blue-500/20 uppercase tracking-widest\\\">\\n      Reserve Table\\n    </button>\\n  </nav>\\n\\n  <!-- Main Content Viewport -->\\n  <main class=\\\"flex-1 grid grid-cols-12 relative overflow-hidden\\\">\\n    <!-- Background Glow -->\\n    <div class=\\\"absolute top-1/4 left-1/4 w-[500px] h-[500px] bg-blue-600/10 rounded-full blur-[120px] pointer-events-none\\\"></div>\\n    \\n    <!-- Left Section: Typography -->\\n    <div class=\\\"col-span-7 flex flex-col justify-center px-12 z-10\\\">\\n      <div class=\\\"flex items-center gap-3 mb-6\\\">\\n        <span class=\\\"w-8 h-[1px] bg-blue-500\\\"></span>\\n        <span class=\\\"text-xs uppercase tracking-[0.4em] text-blue-400 font-bold italic\\\">Michelin Starred Experience</span>\\n      </div>\\n      <h1 class=\\\"text-[84px] leading-[0.9] font-semibold tracking-tighter mb-8\\\">\\n        SAVOUR THE <br/>\\n        <span class=\\\"text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-indigo-600 italic\\\">EXTRAORDINARY.</span>\\n      </h1>\\n      <p class=\\\"text-lg text-slate-400 max-w-lg mb-10 leading-relaxed font-light\\\">\\n        A symphony of flavors, crafted by masters of the culinary arts. \\n        Redefining fine dining through technical precision and local soul.\\n      </p>\\n      <div class=\\\"flex items-center gap-6\\\">\\n        <button class=\\\"px-8 py-4 bg-white text-black font-bold uppercase tracking-wider text-sm rounded-none hover:bg-slate-200 transition-all\\\">\\n          Explore The Menu\\n        </button>\\n        <button class=\\\"flex items-center gap-3 text-sm uppercase tracking-widest font-bold border-b border-white/20 pb-1 hover:border-white transition-all\\\">\\n          View Wine List\\n        </button>\\n      </div>\\n    </div>\\n\\n    <!-- Right Section: Luxury Card/Imagery -->\\n    <div class=\\\"col-span-5 relative flex items-center justify-center pr-12\\\">\\n      <div class=\\\"relative w-full h-[520px] rounded-2xl overflow-hidden shadow-2xl border border-white/10 group\\\">\\n        <div class=\\\"absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-black/20 z-10\\\"></div>\\n        <img src=\\\"https://images.unsplash.com/photo-1559339352-11d035aa65de?auto=format&fit=crop&q=80&w=1000\\\" \\n             alt=\\\"Signature Dish\\\" \\n             class=\\\"absolute inset-0 w-full h-full object-cover scale-105\\\">\\n        \\n        <div class=\\\"absolute bottom-8 left-8 z-20\\\">\\n          <p class=\\\"text-xs uppercase tracking-widest text-blue-400 mb-2 font-bold\\\">Signature Dish</p>\\n          <h3 class=\\\"text-2xl font-serif italic mb-1\\\">Wagyu A5 Striploin</h3>\\n          <p class=\\\"text-sm text-slate-300 font-light\\\">Truffle Jus & Smoked Bone Marrow</p>\\n        </div>\\n        \\n        <div class=\\\"absolute top-8 right-8 z-20\\\">\\n          <div class=\\\"w-16 h-16 rounded-full border border-white/20 flex items-center justify-center backdrop-blur-md\\\">\\n            <span class=\\\"text-xs font-bold\\\">\342\202\2712,450</span>\\n          </div>\\n        </div>\\n      </div>\\n      \\n      <!-- Floating Meta Element -->\\n      <div class=\\\"absolute -bottom-4 -left-8 bg-[#0a0f1d] border border-white/10 p-6 rounded-xl shadow-2xl z-30 flex items-center gap-4\\\">\\n        <div class=\\\"flex flex-col\\\">\\n          <span class=\\\"text-xs opacity-50 uppercase tracking-tighter mb-1\\\">Award Winner</span>\\n          <span class=\\\"text-lg font-bold uppercase\\\">Best Interior 2024</span>\\n        </div>\\n        <div class=\\\"w-px h-10 bg-white/10\\\"></div>\\n        <div class=\\\"flex gap-1 text-blue-500\\\">\\n          <span>\342\230\205</span><span>\342\230\205</span><span>\342\230\205</span><span>\342\230\205</span><span>\342\230\205</span>\\n        </div>\\n      </div>\\n    </div>\\n  </main>\\n\\n  <!-- Bottom Info Rail -->\\n  <footer class=\\\"h-24 w-full border-t border-white/5 flex items-center px-12 bg-black/60 backdrop-blur-sm z-40\\\">\\n    <div class=\\\"grid grid-cols-4 w-full items-center\\\">\\n      <div class=\\\"flex flex-col border-r border-white/5\\\">\\n        <span class=\\\"text-[10px] uppercase tracking-widest text-slate-500 mb-1\\\">Location</span>\\n        <span class=\\\"text-sm font-medium\\\">Cyber Hub, Gurgaon</span>\\n      </div>\\n      <div class=\\\"flex flex-col border-r border-white/5 px-8\\\">\\n        <span class=\\\"text-[10px] uppercase tracking-widest text-slate-500 mb-1\\\">Opening Hours</span>\\n        <span class=\\\"text-sm font-medium\\\">12:00 PM \342\200\224 11:30 PM</span>\\n      </div>\\n      <div class=\\\"flex flex-col border-r border-white/5 px-8\\\">\\n        <span class=\\\"text-[10px] uppercase tracking-widest text-slate-500 mb-1\\\">Contact Us</span>\\n        <span class=\\\"text-sm font-medium\\\">+91 98765 43210</span>\\n      </div>\\n      <div class=\\\"flex justify-end gap-6 items-center pl-8\\\">\\n        <span class=\\\"text-[10px] uppercase tracking-widest text-slate-500\\\">Social</span>\\n        <div class=\\\"flex gap-4\\\">\\n          <div class=\\\"w-8 h-8 rounded-full border border-white/10 flex items-center justify-center hover:bg-white hover:text-black cursor-pointer transition-colors\\\">IG</div>\\n          <div class=\\\"w-8 h-8 rounded-full border border-white/10 flex items-center justify-center hover:bg-white hover:text-black cursor-pointer transition-colors\\\">FB</div>\\n        </div>\\n      </div>\\n    </div>\\n  </footer>\\n</div>\\n                    </body>\\n                  </html>\n[AIS_METADATA_SECTION_END]"
    }
  }
}
