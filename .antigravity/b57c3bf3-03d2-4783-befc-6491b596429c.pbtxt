 facebook: string;\n    tripadvisor?: string;\n  };\n}\n\nexport interface SEOConfig {\n  metaTitle: string;\n  metaDescription: string;\n  keywords: string[];\n  ogImage: string;\n}\n\nexport interface RestaurantConfig {\n  id: string;\n  name: string;\n  logoText: string;\n  colors: ColorPalette;\n  hero: HeroConfig;\n  whyChooseUs: WhyChooseUsItem[];\n  signatureDishes: DishItem[];\n  menu: DishItem[];\n  gallery: GalleryItem[];\n  chef: ChefConfig;\n  reviews: ReviewItem[];\n  contact: ContactConfig;\n  seo: SEOConfig;\n}\n"
