        }
        lines {
          text: "    title: \'Executive Chef & Founder\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    quote: \"A plate is a silent sonnet. It is born of heritage, carved by discipline, and elevated by genuine emotion.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    bio: \"After earning three Michelin stars across legendary Paris and Lyon kitchens, Chef Jean-Luc established L\'\303\211toile to challenge gastronomic conventions. His signature is a respectful deconstruction of classic French sauces blended with local, biodynamic farm yields.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
