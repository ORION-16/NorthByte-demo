  file_change {
    absolute_path_uri: "file:///src/index.css"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "@import url(\'https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500&family=Space+Grotesk:wght@300;400;500;600;700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@300;400;500&family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400&display=swap\');\n@import \"tailwindcss\";\n\n@theme {\n  --font-serif: \'Cormorant Garamond\', \'Playfair Display\', Georgia, serif;\n  --font-sans: \'Plus Jakarta Sans\', \'Space Grotesk\', system-ui, sans-serif;\n  --font-display: \'Space Grotesk\', sans-serif;\n  --font-mono: \'JetBrains Mono\', monospace;\n}\n\n/* Custom Scrollbar */\n::-webkit-scrollbar {\n  width: 6px;\n}\n\n::-webkit-scrollbar-track {\n  background: #030712;\n}\n\n::-webkit-scrollbar-thumb {\n  background: #1f2937;\n  border-radius: 9999px;\n}\n\n::-webkit-scrollbar-thumb:hover {\n  background: var(--color-primary);\n}\n\n/* Smooth Scrolling */\nhtml {\n  scroll-behavior: smooth;\n  background-color: #030712;\n  color: #f3f4f6;\n  -webkit-font-smoothing: antialiased;\n  -moz-osx-font-smoothing: grayscale;\n}\n\n/* Glassmorphism helpers */\n.glass-panel {\n  background: rgba(15, 23, 42, 0.4);\n  backdrop-filter: blur(16px);\n  -webkit-backdrop-filter: blur(16px);\n  border: 1px solid rgba(255, 255, 255, 0.05);\n}\n\n.glass-navbar {\n  background: rgba(3, 7, 18, 0.6);\n  backdrop-filter: blur(20px);\n  -webkit-backdrop-filter: blur(20px);\n  border-bottom: 1px solid rgba(255, 255, 255, 0.03);\n}\n\n/* Gradients & Glows */\n.radial-glow {\n  background: radial-gradient(circle at 50% 50%, rgba(212, 175, 55, 0.1) 0%, transparent 60%);\n}\n\n/* Animations */\n@keyframes pulseGlow {\n  0%, 100% {\n    opacity: 0.2;\n    transform: scale(1);\n  }\n  50% {\n    opacity: 0.4;\n    transform: scale(1.1);\n  }\n}\n\n.animate-glow-slow {\n  animation: pulseGlow 10s infinite ease-in-out;\n}\n\n/* Hide map zoom widgets or other details if necessary, general cleanup */\niframe {\n  filter: grayscale(1) invert(0.9) contrast(1.1);\n}\n"
    }
